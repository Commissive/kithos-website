{
  "strategy": "mobile-first",
  "fluid": {
    "display": "clamp(var(--type-rule-size-max), 3.5vw, var(--type-display-size-max))",
    "section": "clamp(1.5rem, 2.5vw, var(--type-section-size-max))",
    "rule": "clamp(1.25rem, 2vw, var(--type-rule-size-max))",
    "subhead": "clamp(var(--type-body-lg-size-max), 2.5vw, var(--type-subhead-size-max))",
    "ui": "clamp(var(--type-body-sm-size-max), 2vw, var(--type-body-size-max))"
  },
  "display": {
    "fontSizeMax": "48px",
    "fontSize": "var(--type-display-size)",
    "fontFamily": "Schibsted Grotesk",
    "fontWeight": 400,
    "lineHeight": 1.0,
    "letterSpacing": "-0.021em",
    "textTransform": "none",
    "use": "Page titles, hero copy"
  },
  "section": {
    "fontSizeMax": "36px",
    "fontSize": "var(--type-section-size)",
    "fontFamily": "Schibsted Grotesk",
    "fontWeight": 400,
    "lineHeight": 1.05,
    "letterSpacing": "-0.02em",
    "textTransform": "none",
    "use": "Section headlines"
  },
  "rule": {
    "fontSizeMax": "32px",
    "fontSize": "var(--type-rule-size)",
    "fontFamily": "Schibsted Grotesk",
    "fontWeight": 400,
    "lineHeight": 1.1,
    "letterSpacing": "-0.012em",
    "textTransform": "none",
    "use": "Rule statements"
  },
  "subhead": {
    "fontSizeMax": "22px",
    "token": "var(--text-subhead)",
    "fontSize": "var(--type-subhead-size)",
    "fontFamily": "Schibsted Grotesk",
    "fontWeight": 400,
    "lineHeight": 1.2,
    "letterSpacing": "-0.012em",
    "textTransform": "none",
    "use": "Display emphasis — card titles, hero subhead, legal H2s",
    "aliases": [
      "var(--text-display-5)",
      "var(--text-card-title)"
    ]
  },
  "body-lg": {
    "fontSize": "17px",
    "fontFamily": "Hanken Grotesk",
    "fontWeight": 400,
    "lineHeight": 1.5,
    "letterSpacing": "-0.006em",
    "textTransform": "none",
    "use": "Reserved tier — site controls use var(--text-ui) instead"
  },
  "body": {
    "fontSize": "15px",
    "token": "var(--text-body)",
    "fontFamily": "Hanken Grotesk",
    "fontWeight": 400,
    "lineHeight": 1.55,
    "letterSpacing": "0.0em",
    "textTransform": "none",
    "use": "All prose — sections, legal, FAQ, cards, modals"
  },
  "body-sm": {
    "fontSizeMax": "15px",
    "fontSizeMin": "13px",
    "token": "var(--text-ui)",
    "fontFamily": "Hanken Grotesk",
    "fontWeight": 400,
    "lineHeight": 1.5,
    "letterSpacing": "0.0em",
    "textTransform": "none",
    "use": "Compact UI — fluid clamp to 15px; .ui, buttons, pills, labels, meta"
  },
  "caption": {
    "fontSize": "12px",
    "fontFamily": "Hanken Grotesk",
    "fontWeight": 500,
    "lineHeight": 1.4,
    "letterSpacing": "0.008em",
    "textTransform": "none",
    "use": "Captions, fine print"
  },
  "eyebrow": {
    "fontSize": "11px",
    "fontFamily": "IBM Plex Mono",
    "fontWeight": 600,
    "lineHeight": 1.0,
    "letterSpacing": "0.227em",
    "textTransform": "uppercase",
    "use": "Section labels, eyebrows (UPPERCASE)"
  },
  "micro": {
    "fontSize": "10px",
    "fontFamily": "IBM Plex Mono",
    "fontWeight": 600,
    "lineHeight": 1.0,
    "letterSpacing": "0.25em",
    "textTransform": "uppercase",
    "use": "Headers, footers, micro UI (UPPERCASE)"
  },
  "mono-body": {
    "fontSize": "14px",
    "fontFamily": "IBM Plex Mono",
    "fontWeight": 400,
    "lineHeight": 1.5,
    "letterSpacing": "0.0em",
    "textTransform": "none",
    "use": "Data tables, inline code"
  },
  "mono-display": {
    "fontSize": "32px",
    "fontFamily": "IBM Plex Mono",
    "fontWeight": 500,
    "lineHeight": 1.1,
    "letterSpacing": "-0.009em",
    "textTransform": "none",
    "use": "Formulas, data displays"
  },
  "marketingAliases": {
    "display2": "var(--text-display-2)",
    "display3": "var(--text-display-3)",
    "display4": "var(--text-display-4)",
    "display5": "var(--text-display-5)"
  },
  "sectionHeading": {
    "title": {
      "mobile": "clamp(1.625rem, 7.4vw, 2.125rem)",
      "md": "clamp(1.5rem, 2.9vw, 2.5rem)",
      "token": "var(--text-section-heading)"
    },
    "support": {
      "token": "var(--text-section-support)",
      "lineHeight": "var(--lh-section-support)"
    }
  },
  "cardTitle": {
    "token": "var(--text-subhead)"
  },
  "ui": {
    "fontSize": "var(--text-small)",
    "lineHeight": "var(--lh-ui)",
    "letterSpacing": "var(--track-ui)"
  }
}
