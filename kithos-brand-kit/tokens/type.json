{
  "strategy": "mobile-first",
  "fontFamily": "Hanken Grotesk",
  "fluid": {
    "hero": "clamp(1.75rem, 8vw, 2.5rem) — desktop hero.css overrides with container query, capped at 48px",
    "sectionHeading": "clamp(1.625rem, 7.4vw, 2.125rem) → md clamp(2.125rem, 3.1vw, 2.875rem)",
    "flowStatement": "clamp(1.625rem, 5vw, 3rem) → md clamp(2rem, 4.2vw, 3rem)",
    "rule": "clamp(1.25rem, 2vw, var(--type-rule-size-max))",
    "subhead": "clamp(var(--type-body-lg-size-max), 2.5vw, var(--type-subhead-size-max))",
    "ui": "clamp(var(--type-body-sm-size-max), 2vw, var(--type-body-size-max))"
  },
  "hero": {
    "token": "var(--text-hero)",
    "fontFamily": "Hanken Grotesk",
    "fontWeight": 400,
    "lineHeight": "var(--type-hero-leading)",
    "letterSpacing": "var(--type-hero-tracking)",
    "use": "Page hero H1 — .type-hero"
  },
  "sectionHeading": {
    "token": "var(--text-section-heading)",
    "fontFamily": "Hanken Grotesk",
    "fontWeight": 400,
    "lineHeight": "var(--lh-section-heading)",
    "letterSpacing": "var(--type-section-tracking)",
    "mobile": "clamp(1.625rem, 7.4vw, 2.125rem)",
    "md": "clamp(2.125rem, 3.1vw, 2.875rem)",
    "use": "Section titles — .type-statement"
  },
  "flowStatement": {
    "token": "var(--text-flow-statement)",
    "fontFamily": "Hanken Grotesk",
    "fontWeight": 400,
    "lineHeight": "var(--lh-flow-statement)",
    "letterSpacing": "var(--track-flow-statement)",
    "mobile": "clamp(1.625rem, 5vw, 3rem)",
    "md": "clamp(2rem, 4.2vw, 3rem)",
    "measure": "var(--measure-flow-statement)",
    "use": "Flowing lead + support in one block — .type-statement.type-statement--flow"
  },
  "rule": {
    "token": "var(--text-display-4)",
    "fontSizeMax": "32px",
    "fontFamily": "Hanken Grotesk",
    "fontWeight": 400,
    "lineHeight": 1.12,
    "letterSpacing": "-0.014em",
    "use": "Modal titles, rule statements — .type-rule"
  },
  "subhead": {
    "token": "var(--text-subhead)",
    "fontSizeMax": "20px",
    "fontFamily": "Hanken Grotesk",
    "fontWeight": 400,
    "lineHeight": 1.32,
    "letterSpacing": "-0.01em",
    "use": "Card titles, section support, legal H2s — .type-subhead"
  },
  "body": {
    "token": "var(--text-body)",
    "fontSize": "15px",
    "fontFamily": "Hanken Grotesk",
    "fontWeight": 400,
    "lineHeight": 1.58,
    "letterSpacing": "0.004em",
    "use": "All prose — .body"
  },
  "ui": {
    "token": "var(--text-ui)",
    "fontSizeMin": "13px",
    "fontSizeMax": "15px",
    "fontFamily": "Hanken Grotesk",
    "fontWeight": 400,
    "lineHeight": 1.52,
    "letterSpacing": "0.002em",
    "use": "Nav, buttons, form fields — .ui"
  },
  "caption": {
    "fontSize": "12px",
    "fontFamily": "Hanken Grotesk",
    "fontWeight": 400,
    "lineHeight": 1.4,
    "letterSpacing": "0.008em",
    "use": "Captions, fine print"
  },
  "eyebrow": {
    "fontSize": "11px",
    "fontFamily": "Hanken Grotesk",
    "fontWeight": 500,
    "lineHeight": 1.15,
    "letterSpacing": "0.12em",
    "textTransform": "uppercase",
    "use": "Section labels — .label"
  },
  "micro": {
    "fontSize": "10px",
    "fontFamily": "Hanken Grotesk",
    "fontWeight": 500,
    "lineHeight": 1.15,
    "letterSpacing": "0.14em",
    "textTransform": "uppercase",
    "use": "Artifact meta, micro UI"
  },
  "artifact": {
    "title": "var(--text-artifact-title)",
    "body": "var(--text-artifact-body)",
    "label": "var(--text-artifact-label)",
    "meta": "var(--text-artifact-meta)"
  },
  "marketingAliases": {
    "display2": "var(--text-hero)",
    "display3": "var(--text-section-heading)",
    "display4": "var(--text-display-4)",
    "display5": "var(--text-subhead)"
  },
  "utilities": {
    "hero": ".type-hero",
    "statement": ".type-statement",
    "rule": ".type-rule",
    "subhead": ".type-subhead",
    "body": ".body",
    "ui": ".ui",
    "label": ".label"
  }
}
