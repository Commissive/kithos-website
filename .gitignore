# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# claude code worktrees / local
.claude/
.remotion-tmp
.impeccable.md

# design scratch & captured screenshots (not source)
design/
*.jpg
*.jpeg
!public/hero/*.jpg
/logo-ink-512.png

# playwright mcp artifacts
.playwright-mcp/

# test artifacts — runner output and report dirs (snapshots ARE committed)
/test-results/
/playwright-report/
/playwright/.cache/
*.timestamp-*.mjs
